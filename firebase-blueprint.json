{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the DentSide Remote platform, either a dentist or a client.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "photoURL": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["dentist", "client", "admin"],
          "description": "The role of the user on the platform."
        },
        "createdAt": {
          "type": "timestamp"
        },
        "onboardingComplete": {
          "type": "boolean",
          "description": "Whether the user has completed their profile setup."
        }
      },
      "required": ["uid", "email", "role", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    }
  }
}
