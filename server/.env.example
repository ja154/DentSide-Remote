# Copy this file to `server/.env` for backend-only Express configuration.
# Render does not read this file directly; copy the same values into the Render Environment tab.

NODE_ENV="development"
PORT="3000"

# Public URL of the Express server. Required in production.
APP_URL="http://localhost:3000"

# Comma-separated CORS allowlist for browser requests.
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Set to false when the backend is deployed as an API-only service on Render.
SERVE_STATIC_FRONTEND="true"

# Supabase backend configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Example bucket name used by supabase/bootstrap.sql: verification-documents
SUPABASE_STORAGE_BUCKET=

# Optional payment / payout integrations
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
